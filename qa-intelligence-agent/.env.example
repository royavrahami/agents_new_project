# ─────────────────────────────────────────────────────────────────────────────
# QA Intelligence Agent – Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=2000

# ── GitHub (optional – increases rate limits from 60 to 5000 req/hr) ─────────
GITHUB_TOKEN=ghp_...

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./data/qa_agent.db

# ── Scheduler ─────────────────────────────────────────────────────────────────
# How often the agent runs (in hours). Default: every 6 hours.
SCHEDULE_INTERVAL_HOURS=6

# ── Notifications (optional) ──────────────────────────────────────────────────
# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=your_app_password
NOTIFY_EMAIL=your@email.com

# Slack (optional)
SLACK_BOT_TOKEN=xoxb-...
SLACK_CHANNEL=#qa-intelligence

# ── Relevance Scoring ─────────────────────────────────────────────────────────
# Minimum relevance score (0-100) required for an item to be included in reports
MIN_RELEVANCE_SCORE=60

# ── Reports ───────────────────────────────────────────────────────────────────
REPORTS_DIR=./reports

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_DIR=./logs
