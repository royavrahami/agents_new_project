# =====================================================================
# Job Search Multi-Agent System — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# =====================================================================

# --- LLM (Required for full functionality) ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_TEMPERATURE=0.3

# --- Database (SQLite by default, no setup needed) ---
DATABASE_URL=sqlite:///./data/job_search.db

# --- Google Custom Search (Required for Intel Agent) ---
# Get your key: https://developers.google.com/custom-search/v1/overview
# Create CSE:   https://programmablesearchengine.google.com/
GOOGLE_API_KEY=AIza...
GOOGLE_CSE_ID=your-cse-id

# --- Telegram Notifications (Optional) ---
# BotFather: https://t.me/botfather
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Candidate Profile ---
CANDIDATE_NAME=Roy Avrahami
CANDIDATE_ROLE=QA Manager
CANDIDATE_LOCATION=Israel
CANDIDATE_EXPERIENCE_YEARS=14
TARGET_KEYWORDS=QA Manager,Quality Engineering Manager,Head of QA,VP Quality,QA Lead,Test Manager
TARGET_COMPANIES=Wix,Monday.com,Fiverr,Amdocs,Checkpoint,CyberArk,Palo Alto Networks,Varonis,SentinelOne,Zscaler,Armis,Orca Security

# --- Outreach Settings ---
OUTREACH_DAILY_LIMIT=15
FOLLOW_UP_DAYS=5

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=logs/job_search_agents.log
